# Tap repositories for additional Homebrew formulas
tap "bramstein/webfonttools" # Tools for working with web fonts. [Webfonttools](https://github.com/bramstein/homebrew-webfonttools)
tap "buo/cask-upgrade" # Upgrade cask packages quickly. [Cask Upgrade](https://github.com/buo/homebrew-cask-upgrade)
tap "coder/coder" # Developer tools from Coder. [Coder](https://github.com/coder/homebrew-coder)
tap "derailed/popeye" # A Kubernetes cluster resource sanitizer. [Popeye](https://github.com/derailed/popeye)
tap "goodwithtech/r" # Tools for Kubernetes security. [R](https://github.com/goodwithtech/homebrew-r)
tap "hashicorp/tap" # HashiCorp tools. [HashiCorp](https://developer.hashicorp.com/terraform)
tap "homebrew/command-not-found" # Command-not-found hook for Homebrew. [Homebrew Command Not Found](https://github.com/Homebrew/homebrew-command-not-found)
tap "joshmedeski/sesh" # Sesh: A tool for managing shell sessions. [Sesh](https://github.com/joshmedeski/sesh)
tap "kubeshark/kubeshark" # API traffic viewer for Kubernetes. [Kubeshark](https://github.com/kubeshark/homebrew-tap)
tap "lotyp/formulae" # Various useful Homebrew formulas. [Lotyp Formulae](https://github.com/lotyp/homebrew-formulae)
tap "molovo/revolver" # Revolver: A simple command-line tool for rotating text. [Revolver](https://github.com/molovo/revolver)
tap "qmk/qmk" # QMK Firmware. [QMK](https://qmk.fm/)
tap "robusta-dev/homebrew-holmesgpt" # AI-powered Kubernetes troubleshooting. [HolmesGPT](https://github.com/robusta-dev/holmesgpt)
tap "robusta-dev/homebrew-krr" # Kubernetes Resource Reporter. [KRR](https://github.com/robusta-dev/krr)
tap "sst/tap" # SST tools. [SST](https://github.com/sst/opencode)
