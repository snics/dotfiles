# Beispiel-Datei für ~/.secrets
# Kopiere diese Datei nach ~/.secrets und trage deine echten Werte ein.
# ~/.secrets wird von ~/.zshrc automatisch geladen und ist in .gitignore.
#
# Alternativ: Secrets aus dem macOS Keychain laden (siehe unten).

# =============================================================================
# Git
# =============================================================================

git config --global user.name "FIRST_NAME LAST_NAME"
git config --global user.email "MY_NAME@example.com"
git config --global github.user MY_USERNAME
git config --global github.token MY_TOKEN

git config --global gpg.program /usr/local/bin/gpg
git config --global commit.gpgsign true
git config --global user.signingkey MY_SIGNINGKEY

# =============================================================================
# AI / LLM API Keys
# =============================================================================

# OpenAI
# export OPENAI_API_KEY="sk-..."
# export OPENAI_ORG_ID="org-..."                  # optional

# Anthropic / Claude
# export ANTHROPIC_API_KEY="sk-ant-..."

# Google Gemini
# export GEMINI_API_KEY="..."
# export GOOGLE_API_KEY="..."                      # alternativ, hat Vorrang

# OpenRouter
# export OPENROUTER_API_KEY="sk-or-..."

# Context7 (Upstash) — genutzt von Claude Code MCP & Cursor MCP
# export CONTEXT7_API_KEY="ctx7sk_..."
