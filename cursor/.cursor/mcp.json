{
  "$schema": "https://cdn.jsdelivr.net/gh/anthropics/claude-code@main/config-schemas/mcp.v1.schema.json",
  "mcpServers": {
    "figma-desktop": {
      "url": "http://127.0.0.1:3845/mcp"
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      }
    },
    "linear": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ]
    },
    "grep_app": {
      "type": "http",
      "url": "https://mcp.grep.app"
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide"
      ]
    },
    "git": {
      "command": "npx",
      "args": [
        "@cyanheads/git-mcp-server@latest"
      ]
    }
  }
}