{
  "serena": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server",
      "--context=claude-code",
      "--project-from-cwd",
      "--open-web-dashboard",
      "False"
    ],
    "env": {}
  },
  "grep": {
    "type": "http",
    "url": "https://mcp.grep.app"
  },
  "context7": {
    "type": "http",
    "url": "https://mcp.context7.com/mcp",
    "headers": {
      "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
    }
  }
}
