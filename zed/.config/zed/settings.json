{
  "edit_predictions": {
    "provider": "zed"
  },
  // =====================================================================
  // Theme
  // =====================================================================
  "theme": "Catppuccin Macchiato",
  "icon_theme": "Catppuccin Macchiato",
  // =====================================================================
  // Fonts
  // =====================================================================
  "buffer_font_family": "Lilex Nerd Font",
  "buffer_font_size": 15,
  "buffer_font_features": {
    "calt": true, // (default)
    "liga": true,
  },
  "buffer_line_height": "comfortable",
  "ui_font_family": "Lilex Nerd Font",
  "ui_font_size": 15,
  "ui_font_features": {
    "calt": true, // (default)
  },
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 14,
  // =====================================================================
  // Editor
  // =====================================================================
  "tab_size": 2, // (default)
  "hard_tabs": false, // use spaces instead of tab
  "soft_wrap": "none",
  "preferred_line_length": 80,
  "show_wrap_guides": true,
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,
  "show_whitespaces": "all",
  "colorize_brackets": true,
  "jsx_tag_auto_close": {
    "enabled": true
  }, // (default)
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "semantic_tokens": "combined",
  // Inlay Hints
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true, // (default)
    "show_parameter_hints": true, // (default)
    "show_value_hints": true, // (default)
    "show_other_hints": true, // (default)
    "show_background": false, // (default)
    "edit_debounce_ms": 700, // (default)
    "scroll_debounce_ms": 50, // (default)
  },
  // Inline Diagnostics
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  // Indent Guides
  "indent_guides": {
    "enabled": true, // (default)
    "line_width": 1, // (default)
    "active_line_width": 2,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  // Edit Predictions — Zeta
  // =====================================================================
  // UI Panels
  // =====================================================================
  // Tabs
  "tabs": {
    "git_status": true, // (default)
    "file_icons": true, // (default)
    "show_close_button": "hover", // (default)
    "activate_on_close": "history",
    "show_diagnostics": "all",
  },
  // Minimap — disabled (Vim navigation is sufficient)
  "minimap": {
    "show": "never",
  },
  // Scrollbar
  "scrollbar": {
    "show": "auto", // (default)
    "cursors": true, // (default)
    "git_diff": true, // (default)
    "search_results": true, // (default)
    "selected_text": true, // (default)
    "selected_symbol": true, // (default)
    "diagnostics": "all", // (default)
  },
  // Gutter
  "gutter": {
    "line_numbers": true, // (default)
    "runnables": true, // (default)
    "breakpoints": true, // (default)
    "folds": true, // (default)
    "min_line_number_digits": 2,
  },
  // Project Panel
  "project_panel": {
    "starts_open": false,
    "auto_fold_dirs": true, // (default)
    "bold_folder_labels": true, // (default)
    "hide_gitignore": false, // (default)
    "hide_hidden": false, // (default)
    "hide_root": false, // (default)
    "auto_open": {
      "on_create": true,
      "on_paste": false,
      "on_drop": false,
    },
  },
  // =====================================================================
  // Vim Mode
  // =====================================================================
  "vim_mode": true,
  "vim": {
    "default_mode": "normal", // (default)
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 200,
    "cursor_shape": {
      "normal": "block", // (default)
      "insert": "bar", // (default)
      "visual": "block", // (default)
      "replace": "underline", // (default)
    },
  },
  "use_smartcase_search": true,
  // Which-Key Popup (similar to which-key.nvim)
  "which_key": {
    "enabled": true,
    "delay_ms": 200,
  },
  // =====================================================================
  // Terminal
  // =====================================================================
  "terminal": {
    "font_size": 15,
    "option_as_meta": true,
    "line_height": "comfortable",
    "working_directory": "current_project_directory",
    "alternate_scroll": "on", // (default)
    "copy_on_select": false, // (default)
    "toolbar": {
      "breadcrumbs": true
    }, // (default)
    "detect_venv": {
      "on": {
        "directories": [
          ".venv",
          "venv"
        ], // (default)
        "activate_script": "default", // (default)
      },
    },
    "max_scroll_history_lines": 10000, // (default)
  },
  // =====================================================================
  // AI Agent — OpenRouter
  // =====================================================================
  "agent": {
    "favorite_models": [],
    "inline_assistant_model": {
      "provider": "openrouter",
      "model": "openrouter/free"
    },
    "model_parameters": []
  },
  // OpenRouter — available models
  "language_models": {
    "open_router": {
      "available_models": [
        // =============================================================
        // Anthropic
        // =============================================================
        {
          "name": "anthropic/claude-opus-4.6",
          "display_name": "Claude Opus 4.6",
          "max_tokens": 1000000,
          "max_output_tokens": 128000,
        },
        {
          "name": "anthropic/claude-sonnet-4.5",
          "display_name": "Claude Sonnet 4.5",
          "max_tokens": 1000000,
          "max_output_tokens": 64000,
        },
        {
          "name": "anthropic/claude-haiku-4.5",
          "display_name": "Claude Haiku 4.5",
          "max_tokens": 200000,
          "max_output_tokens": 64000,
        },
        // =============================================================
        // OpenAI
        // =============================================================
        {
          "name": "openai/gpt-5.2-codex",
          "display_name": "GPT-5.2 Codex",
          "max_tokens": 400000,
          "max_output_tokens": 128000,
        },
        {
          "name": "openai/gpt-5-codex",
          "display_name": "GPT-5 Codex",
          "max_tokens": 400000,
          "max_output_tokens": 128000,
        },
        {
          "name": "openai/o4-mini",
          "display_name": "o4 Mini",
          "max_tokens": 200000,
          "max_output_tokens": 100000,
        },
        // =============================================================
        // Google
        // =============================================================
        {
          "name": "google/gemini-3-pro-preview",
          "display_name": "Gemini 3 Pro Preview",
          "max_tokens": 1048576,
          "max_output_tokens": 65535,
        },
        {
          "name": "google/gemini-3-flash-preview",
          "display_name": "Gemini 3 Flash Preview",
          "max_tokens": 1048576,
          "max_output_tokens": 65535,
        },
        {
          "name": "google/gemini-2.5-flash",
          "display_name": "Gemini 2.5 Flash",
          "max_tokens": 1048576,
          "max_output_tokens": 65535,
        },
        {
          "name": "google/gemini-2.5-flash-lite",
          "display_name": "Gemini 2.5 Flash Lite",
          "max_tokens": 1048576,
          "max_output_tokens": 65535,
        },
        // =============================================================
        // Other (Paid)
        // =============================================================
        {
          "name": "moonshotai/kimi-k2.5",
          "display_name": "Kimi K2.5",
          "max_tokens": 262144,
          "max_output_tokens": 65535,
        },
        {
          "name": "deepseek/deepseek-v3.2",
          "display_name": "DeepSeek V3.2",
          "max_tokens": 164000,
          "max_output_tokens": 65535,
        },
        // =============================================================
        // Free — ":free" = OpenRouter Free Tier
        // If free tier ends, switch to paid ID without ":free"
        // =============================================================
        {
          "name": "qwen/qwen3-coder:free",
          "display_name": "Qwen3 Coder (free)",
          "max_tokens": 262000,
          "max_output_tokens": 262000,
        },
        {
          "name": "openai/gpt-oss-120b:free",
          "display_name": "GPT-OSS 120B (free)",
          "max_tokens": 131072,
          "max_output_tokens": 131072,
        },
        {
          "name": "google/gemini-2.5-flash:free",
          "display_name": "Gemini 2.5 Flash (free)",
          "max_tokens": 1048576,
          "max_output_tokens": 65535,
        },
      ],
    },
  },
  // =====================================================================
  // MCP Context Servers
  // =====================================================================
  "context_servers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}",
      },
    },
    "grep_app": {
      "url": "https://mcp.grep.app",
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
      ],
      "env": {},
    },
  },
  // =====================================================================
  // Language Overrides
  // =====================================================================
  "languages": {
    "Go": {
      "tab_size": 4,
      "hard_tabs": true,
      "format_on_save": "on",
      "preferred_line_length": 100,
    },
    "Rust": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "preferred_line_length": 100,
    },
    // JS/TS: Biome (if biome.json exists) > Prettier fallback
    "TypeScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        {
          "external": {
            "command": "prettier",
            "arguments": [
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        },
      ],
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "TSX": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        {
          "external": {
            "command": "prettier",
            "arguments": [
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        },
      ],
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "JavaScript": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        {
          "external": {
            "command": "prettier",
            "arguments": [
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        },
      ],
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true,
      },
    },
    "Python": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
      "preferred_line_length": 88,
      "soft_wrap": "preferred_line_length",
    },
    "Lua": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": [
            "--indent-type",
            "Spaces",
            "--indent-width",
            "2",
            "--quote-style",
            "AutoPreferDouble",
            "-",
          ],
        },
      },
    },
    "Shell Script": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": [
            "-i",
            "2",
            "-ci"
          ],
        },
      },
    },
    "YAML": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "JSON": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        "language_server",
      ],
    },
    "JSONC": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        "language_server",
      ],
    },
    "SQL": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "sqlfluff",
          "arguments": [
            "format",
            "--dialect",
            "postgres",
            "-"
          ],
        },
      },
    },
    "Terraform": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "HCL": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "TOML": {
      "tab_size": 2,
      "format_on_save": "on",
    },
    "Markdown": {
      "tab_size": 2,
      "soft_wrap": "editor_width",
      "format_on_save": "off",
    },
    "CSS": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        {
          "external": {
            "command": "prettier",
            "arguments": [
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        },
      ],
    },
    "SCSS": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ],
        },
      },
    },
    "HTML": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ],
        },
      },
    },
    "GraphQL": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": [
        {
          "language_server": {
            "name": "biome"
          }
        },
        {
          "external": {
            "command": "prettier",
            "arguments": [
              "--stdin-filepath",
              "{buffer_path}"
            ]
          }
        },
      ],
    },
    "Dart": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "Zig": {
      "tab_size": 4,
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "Nix": {
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": "language_server",
    },
    "LaTeX": {
      "tab_size": 2,
      "soft_wrap": "preferred_line_length",
      "format_on_save": "off",
    },
    "Dockerfile": {
      "tab_size": 4,
    },
    "Helm": {
      "tab_size": 2,
    },
  },
  // =====================================================================
  // LSP Server Settings
  // =====================================================================
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "cargo": {
          "allFeatures": true,
        },
        "procMacro": {
          "enable": true,
        },
      },
    },
    "gopls": {
      "initialization_options": {
        "usePlaceholders": true,
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "parameterNames": true,
        },
      },
    },
    // Biome: only activate when biome.json exists in project
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "schemaStore": {
            "enable": true,
          },
          "format": {
            "enable": true,
          },
        },
      },
    },
  },
  // =====================================================================
  // System
  // =====================================================================
  "auto_update": true, // (default)
  "load_direnv": "shell_hook",
  "auto_install_extensions": {
    // Themes & Icons
    "catppuccin-icons": true,
    "catppuccin": true,
    // Languages
    "html": true,
    "toml": true,
    "dockerfile": true,
    "sql": true,
    "make": true,
    "lua": true,
    "xml": true,
    "terraform": true,
    "latex": true,
    "dart": true,
    "zig": true,
    "nix": true,
    "csv": true,
    "graphql": true,
    "proto": true,
    "ini": true,
    "just": true,
    "ansible": true,
    "helm": true,
    "go": true,
    // Python
    "basedpyright": true,
    "ruff": true,
    "scss": true,
    // JS/TS Tooling
    "biome": true,
    "emmet": true,
    // Docker
    "docker-compose": true,
    // Shell
    "basher": true,
    // Editor Utilities
    "color-highlight": true,
    "snippets": true,
    // Git & Utilities
    "git-firefly": true,
    "rainbow-csv": true,
    "comment": true,
    "ghostty": true,
    // Snippets
    "react-typescript-snippets": true,
    "go-snippets": true,
    "rust-snippets": true,
    "python-snippets": true,
    // Tools
    "tombi": true,
  },
  // Telemetry
  "telemetry": {
    "diagnostics": true, // (default) — crash reports
    "metrics": false, // usage statistics disabled
  },
}
