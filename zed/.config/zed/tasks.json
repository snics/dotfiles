[
  // =====================================================================
  // Go
  // =====================================================================
  {
    "label": "go test ./...",
    "command": "go test ./...",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "go test (current package)",
    "command": "go test ./$ZED_RELATIVE_DIR/...",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
  {
    "label": "go run",
    "command": "go run $ZED_FILE",
    "reveal": "always"
  },
  {
    "label": "go build",
    "command": "go build ./...",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "on_success"
  },
  {
    "label": "go mod tidy",
    "command": "go mod tidy",
    "cwd": "$ZED_WORKTREE_ROOT",
    "hide": "on_success"
  },
  {
    "label": "golangci-lint",
    "command": "golangci-lint run ./...",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "always"
  },
